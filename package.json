{
  "name": "ctf-ics-mobile-ui",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/ctf-ics-mobile-ui.umd.js",
  "module": "./dist/ctf-ics-mobile-ui.js",
  "exports": {
    ".": {
      "import": "./dist/ctf-ics-mobile-ui.js",
      "require": "./dist/ctf-ics-mobile-ui.js"
    },
    "./*": "./*"
  },
  "homepage": "",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && npm run tar",
    "preview": "vite preview",
    "build:doc": "vite build --config ./build/build.js",
    "gc": "node scripts/gc.js",
    "ge": "node scripts/build-entry.js",
    "new": "node scripts/create.js create",
    "dc": "node scripts/dc.js",
    "precommit": "lint-staged -c ./.husky/.lintstagedrc -q --allow-empty",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "gc2": "node test/gc.js",
    "tar": "node build/tar.js"
  },
  "dependencies": {
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@vant/touch-emulator": "^1.5.0",
    "@vue/test-utils": "^2.0.0",
    "commander": "^11.0.0",
    "element-plus": "2.6.3",
    "highlight.js": "^11.8.0",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.1",
    "pinia": "^2.0.12",
    "prettier": "^2.8.8",
    "sass": "^1.49.7",
    "stylelint": "^15.10.3",
    "stylelint-config-standard": "^34.0.0",
    "stylelint-prettier": "^3.0.0",
    "transliteration": "^2.6.0",
    "unplugin-vue-markdown": "^30.0.0",
    "vant": "^4.9.22",
    "vite-plugin-vue-markdown": "^0.23.8",
    "vue": "^3.3.4",
    "vue-router": "^4.0.14"
  },
  "devDependencies": {
    "@rollup/plugin-replace": "^6.0.3",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vitejs/plugin-vue-jsx": "^3.0.2",
    "chalk": "^5.6.2",
    "consola": "^3.2.3",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "fast-glob": "^3.3.1",
    "file-save": "^0.2.0",
    "inquirer": "^9.2.11",
    "jsdom": "^16.7.0",
    "json-templater": "^1.2.0",
    "kolorist": "^1.8.0",
    "postcss-change-css-prefix": "^1.0.4",
    "tar": "^7.5.11",
    "unplugin-auto-import": "^0.18.3",
    "unplugin-vue-components": "^0.27.5",
    "vite": "^4.4.5",
    "vitest": "^1.6.0",
    "vue-eslint-parser": "^9.3.1"
  }
